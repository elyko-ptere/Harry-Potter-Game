// ─── NOTIFICATIONS ────────────────────────────────
function notify(title, text, type = 'xp', icon = '⭐') {
  const container = document.getElementById('notifications');
  const div = document.createElement('div');
  div.className = `notif ${type}`;
  div.innerHTML = `<span class="notif-icon">${icon}</span>
    <div class="notif-text">
      <div class="notif-title">${title}</div>
      <div>${text}</div>
    </div>`;
  container.appendChild(div);
  setTimeout(() => div.remove(), 3800);
}

// ─── FLOATING TEXT ────────────────────────────────
function floatText(text, color = 'var(--gold)') {
  const el = document.createElement('div');
  el.className = 'float-particle';
  el.style.cssText = `color:${color};left:${rand(30,70)}%;top:${rand(30,60)}%;font-weight:bold;`;
  el.textContent = text;
  document.getElementById('world').appendChild(el);
  setTimeout(() => el.remove(), 2000);
}

// ─── XP SYSTEM ───────────────────────────────────
function gainXP(amount) {
  if (amount <= 0) return;
  STATE.player.xp += amount;
  STATE.player.xpTotal += amount;
  floatText(`+${amount} XP`, 'var(--gold)');

  while (STATE.player.xp >= STATE.player.xpNext) {
    STATE.player.xp -= STATE.player.xpNext;
    levelUp();
  }
  updateHUD();
  saveGame();
}

function gainSkillXP(skill, amount) {
  if (!STATE.player.skills[skill] !== undefined) return;
  STATE.player.skills[skill] = (STATE.player.skills[skill] || 0) + amount;
  if (STATE.player.skills[skill] > 100) STATE.player.skills[skill] = 100;
  notify('Compétence Améliorée', `+${amount} en ${skill}`, 'success', '⚡');
  saveGame();
}

function levelUp() {
  STATE.player.level++;
  STATE.player.xpNext = Math.floor(STATE.player.xpNext * 1.4);
  STATE.player.hpMax += 10;
  STATE.player.mpMax += 5;
  STATE.player.hp = STATE.player.hpMax;
  STATE.player.mp = STATE.player.mpMax;

  if (STATE.player.level % 7 === 0) {
    STATE.player.year = Math.min(7, STATE.player.year + 1);
    notify('Nouvelle Année!', `Vous passez en ${STATE.player.year}ème année!`, 'success', '🎓');
  }

  document.getElementById('levelup-text').textContent = `Vous avez atteint le niveau ${STATE.player.level}!`;
  document.getElementById('levelup-bonus').textContent = `+10 HP Max, +5 MP Max, +${STATE.player.level * 5} Points de Maison`;
  document.getElementById('levelup-screen').style.display = 'flex';
  saveGame();
}

function healPlayer(amount) {
  STATE.player.hp = clamp(STATE.player.hp + amount, 0, STATE.player.hpMax);
  floatText(`+${amount} HP`, '#ff4444');
  updateHUD();
}

function restoreMP(amount) {
  STATE.player.mp = clamp(STATE.player.mp + amount, 0, STATE.player.mpMax);
  floatText(`+${amount} MP`, '#4488ff');
  updateHUD();
}

