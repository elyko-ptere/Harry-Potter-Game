      const btn = document.createElement('div');
      btn.className = 'quiz-answer';
      btn.textContent = a.text;
      btn.onclick = () => {
        sortingScores[a.trait]++;
        sortingQuestionIdx++;
        Game.showSortingQuestion();
      };
      answersEl.appendChild(btn);
    });
  },

  revealHouse() {
    document.getElementById('quiz-container').style.display = 'none';
    const scores = sortingScores;
    let house = 'gryffondor';
    const maxScore = Math.max(scores.courage, scores.loyalty, scores.intelligence, scores.cunning);
    if (scores.courage === maxScore) house = 'gryffondor';
    else if (scores.intelligence === maxScore) house = 'serdaigle';
    else if (scores.loyalty === maxScore) house = 'poufsouffle';
    else house = 'serpentard';

    STATE.player.house = house;
    const h = HOUSES[house];
    document.getElementById('house-badge').textContent = h.badge;
    document.getElementById('house-name-display').textContent = h.name;
    document.getElementById('house-motto').textContent = h.motto;
    document.getElementById('house-name-display').style.color = h.color;
    document.getElementById('house-result').style.display = 'block';

    notify('Maison Révélée!', `Bienvenue à ${h.name}!`, 'success', h.badge);
  },

  finishCreation() {
    document.getElementById('sorting-hat').style.display = 'none';
    STATE.game.started = true;
    STATE.game.sortingDone = true;
    // Give starter inventory
    addToInventory('potion_soin');
    addToInventory('parchemin');
    this.launchWorld();
    saveGame();
    // Start main quest
    setTimeout(() => { this.talkToNPC('dumbledore'); }, 2000);
  },

  launchWorld() {
    document.getElementById('hud').style.display = 'flex';
    document.getElementById('bottom-nav').style.display = 'flex';
    document.getElementById('world').style.display = 'block';
    document.getElementById('minimap').style.display = 'block';
    updateHUD();
    this.updatePlayerSprite();
    this.setScene('hogwarts');
    updateWeather();
    setInterval(tickTime, 8000); // 1 real second = 2 game minutes
  },

  updatePlayerSprite() {
    document.getElementById('player-sprite').textContent = STATE.player.avatar;
    document.getElementById('player-tag').textContent = STATE.player.name;
    document.getElementById('player').style.cssText = 'left:50%;top:50%;transform:translate(-50%,-50%)';
  },

