    () => { gainXP(30); },
    () => { STATE.player.mp = STATE.player.mpMax; notify('Bonbon!', 'Énergie magique restaurée!', 'success', '🍬'); },
    () => { STATE.player.hp = Math.max(1, STATE.player.hp - 10); notify('Surprise!', 'Aïe... Saveur piment -10 HP', 'warning', '🌶️'); }
  ];
  effects[rand(0, effects.length-1)]();
  updateHUD();
}

// ─── HUD UPDATE ───────────────────────────────────
function updateHUD() {
  const p = STATE.player;
  document.getElementById('hud-avatar').textContent = p.avatar;
  document.getElementById('hud-name').textContent = p.name;
  document.getElementById('hud-level').textContent = p.level;
  document.getElementById('hud-galleons').textContent = '💰 ' + p.galleons;
  document.getElementById('hp-bar').style.width = (p.hp / p.hpMax * 100) + '%';
  document.getElementById('mp-bar').style.width = (p.mp / p.mpMax * 100) + '%';
  document.getElementById('xp-bar').style.width = (p.xp / p.xpNext * 100) + '%';
  document.getElementById('hp-text').textContent = `${p.hp}/${p.hpMax}`;
  document.getElementById('mp-text').textContent = `${p.mp}/${p.mpMax}`;
  document.getElementById('xp-text').textContent = `${p.xp}/${p.xpNext}`;
  document.getElementById('hud-house').textContent = HOUSES[p.house]?.badge || '🦁';
  updateTimeDisplay();
}

function updateTimeDisplay() {
  const w = STATE.world;
  const h = Math.floor(w.time / 60);
  const m = w.time % 60;
  const timeStr = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
  const period = h >= 6 && h < 12 ? '🌅' : h >= 12 && h < 18 ? '☀️' : h >= 18 && h < 21 ? '🌆' : '🌙';
  document.getElementById('hud-time').textContent = `${period} ${timeStr}`;
  const weathers = { clear: '☀️', rain: '🌧️', snow: '❄️', fog: '🌫️', storm: '⛈️', magic: '✨' };
  document.getElementById('hud-weather').textContent = weathers[w.weather] || '☀️';
}

// ─── TIME & WEATHER SYSTEM ───────────────────────
function tickTime() {
  STATE.world.time = (STATE.world.time + 1) % (24 * 60);
  updateDayNight();
  if (STATE.world.time % 60 === 0) updateNPCRoutines();
  // Weather changes
  STATE.world.weatherTimer++;
  if (STATE.world.weatherTimer > 20 + rand(0,40)) {
    const weathers = ['clear','clear','clear','rain','snow','fog','storm','magic'];
    STATE.world.weather = weathers[rand(0, weathers.length-1)];
    STATE.world.weatherTimer = 0;
    updateWeather();
  }
  updateTimeDisplay();
  saveGame();
}

function updateDayNight() {
  const h = Math.floor(STATE.world.time / 60);
  const overlay = document.getElementById('daynight');
  let color = 'transparent';
  if (h >= 21 || h < 6) color = 'rgba(0,0,30,0.6)';
  else if (h < 8) color = 'rgba(20,5,0,0.3)';
  else if (h >= 18) color = 'rgba(30,10,0,0.3)';
  overlay.style.background = color;
}

function updateWeather() {
  const overlay = document.getElementById('weather-overlay');
  overlay.innerHTML = '';
  const w = STATE.world.weather;
  if (w === 'rain') {
    for (let i = 0; i < 40; i++) {
      const drop = document.createElement('div');
      drop.className = 'rain-drop';
      drop.style.cssText = `left:${rand(0,100)}%;animation-duration:${0.5+Math.random()*0.5}s;animation-delay:${Math.random()*1}s;`;
      overlay.appendChild(drop);
    }
  } else if (w === 'snow') {
    for (let i = 0; i < 25; i++) {
      const flake = document.createElement('div');
      flake.className = 'snow-flake';
      flake.textContent = '❄';
      flake.style.cssText = `left:${rand(0,100)}%;animation-duration:${2+Math.random()*3}s;animation-delay:${Math.random()*2}s;`;
      overlay.appendChild(flake);
    }
  } else if (w === 'magic') {
    const colors = ['#ff88ff','#88aaff','#ffdd44','#44ffaa'];
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'magic-particle';
      p.style.cssText = `left:${rand(0,100)}%;background:${colors[rand(0,3)]};box-shadow:0 0 6px ${colors[rand(0,3)]};animation-duration:${3+Math.random()*4}s;animation-delay:${Math.random()*3}s;`;
      overlay.appendChild(p);
    }
    notify('Magie dans l\'air!', 'Des particules magiques flottent autour de vous...', 'quest', '✨');
  }
}

function updateNPCRoutines() {
  const h = Math.floor(STATE.world.time / 60);
  if (h === 8) notify('PNJ', 'Les cours commencent à Poudlard!', 'quest', '📚');
  if (h === 12) notify('PNJ', 'L\'heure du repas à la Grande Salle!', 'quest', '🍽️');
  if (h === 19) notify('PNJ', 'Le soir tombe sur Poudlard...', 'quest', '🌙');
  if (h === 23) notify('Couvre-feu', 'Rentrez dans votre dortoir!', 'warning', '⚠️');
}

// ─── MAIN GAME OBJECT ────────────────────────────
const Game = {
  startGame() {
    document.getElementById('splash').style.display = 'none';
    const saved = loadGame();
    if (saved && STATE.game.started) {
      this.launchWorld();
      notify('Partie Chargée', 'Bienvenue à nouveau!', 'success', '✨');
    } else {
      document.getElementById('char-creation').style.display = 'flex';
    }
  },

  goToSortingHat() {
    const nameInput = document.getElementById('char-name').value.trim();
    if (!nameInput) {
      alert('Entrez votre nom de sorcier!');
      return;
    }
    STATE.player.name = nameInput;
    STATE.player.avatar = charSelections.avatar;
    STATE.player.wand = charSelections.wand;
    STATE.player.wandName = charSelections.wandName;
    STATE.player.pet = charSelections.pet;
    STATE.player.petName = charSelections.petName;

    document.getElementById('char-creation').style.display = 'none';
    document.getElementById('sorting-hat').style.display = 'flex';
    sortingQuestionIdx = 0;
    sortingScores = { courage: 0, loyalty: 0, intelligence: 0, cunning: 0 };
    this.showSortingQuestion();
  },

  showSortingQuestion() {
    if (sortingQuestionIdx >= SORTING_QUESTIONS.length) {
      this.revealHouse();
      return;
    }
    const q = SORTING_QUESTIONS[sortingQuestionIdx];
    document.getElementById('hat-speech').textContent = `Question ${sortingQuestionIdx + 1}/${SORTING_QUESTIONS.length}`;
    document.getElementById('quiz-question').textContent = `« ${q.text} »`;
