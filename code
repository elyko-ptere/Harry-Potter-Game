  document.querySelectorAll('#avatar-grid .avatar-option').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected');
  charSelections.avatar = avatar;
}
function selectWand(el, icon, name) {
  document.querySelectorAll('.wand-option').forEach(e => e.classList.remove('selected'));
  el.classList.add('selected');
  charSelections.wand = icon;
  charSelections.wandName = name;
}
function selectPet(el, icon, name) {
