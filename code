// ─── UTILITY FUNCTIONS ───────────────────────────
function rand(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
function clamp(val, min, max) { return Math.max(min, Math.min(max, val)); }
function saveGame() {
  try { localStorage.setItem('poudlard_save', JSON.stringify(STATE)); } catch(e) {}
}
function loadGame() {
  try {
    const s = localStorage.getItem('poudlard_save');
    if (s) { Object.assign(STATE, JSON.parse(s)); return true; }
  } catch(e) {}
  return false;
}
function switchTab(panelId, tabId) {
  const panel = document.getElementById('panel-' + panelId);
  panel.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  panel.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.getElementById('tab-' + panelId + '-' + tabId).classList.add('active');
}
