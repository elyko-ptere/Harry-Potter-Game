/* ═══ PROFILE SCREEN ═══ */
#profile-screen {
  position: fixed;
  inset: 70px 0 70px;
  background: rgba(0,0,0,0.85);
  backdrop-filter: blur(8px);
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 20px;
  overflow-y: auto;
  z-index: 200;
}

.profile-card {
  background: var(--panel-bg);
  border: 1px solid var(--panel-border);
  border-radius: 8px;
  padding: 24px;
  max-width: 480px;
  width: 100%;
  margin-bottom: 12px;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--panel-border);
}

.profile-avatar-big {
  width: 64px; height: 64px;
  background: rgba(240,192,64,0.1);
  border: 2px solid var(--gold);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 32px;
  box-shadow: var(--glow-gold);
}

.profile-name {
  font-family: var(--font-title);
  font-size: 22px;
  color: var(--gold);
}

.profile-house {
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--parchment-dark);
  margin-top: 4px;
}

.profile-year {
  font-size: 11px;
  font-family: var(--font-ui);
  color: var(--gold-dim);
  margin-top: 2px;
}

.stat-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}

.stat-box {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(240,192,64,0.15);
  border-radius: 6px;
  padding: 10px;
  text-align: center;
}

.stat-box-val {
  font-family: var(--font-ui);
  font-size: 22px;
  color: var(--gold);
  display: block;
}

.stat-box-lbl {
  font-size: 10px;
  color: var(--parchment-dark);
  font-family: var(--font-ui);
  letter-spacing: 1px;
}

/* ═══ RELATIONSHIP SYSTEM ═══ */
.npc-relations {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.relation-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px;
  border: 1px solid rgba(240,192,64,0.1);
  border-radius: 5px;
}

.relation-icon { font-size: 20px; }
.relation-name { font-family: var(--font-ui); font-size: 12px; color: var(--gold); flex: 1; }

.relation-bar {
  width: 80px; height: 6px;
  background: rgba(255,255,255,0.08);
  border-radius: 3px;
  overflow: hidden;
}

.relation-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, #884444, #ff8888, #44aa44);
  transition: width 0.5s;
}

/* ═══ FLOATING PARTICLES ═══ */
.float-particle {
  position: absolute;
  pointer-events: none;
  animation: floatUp 2s ease-out forwards;
  font-family: var(--font-ui);
  font-size: 14px;
  z-index: 500;
}

@keyframes floatUp {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(-60px); opacity: 0; }
}

/* ═══ SCENE BACKGROUNDS ═══ */
.bg-hogwarts-sky {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 55%;
  background: linear-gradient(180deg,
    #050215 0%,
    #0a0428 30%,
    #140840 60%,
    #1a0a50 100%
  );
}

.bg-stars {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 40%;
  background-image:
    radial-gradient(1px 1px at 5% 10%, white, transparent),
    radial-gradient(1px 1px at 15% 25%, rgba(255,255,255,0.8), transparent),
    radial-gradient(2px 2px at 25% 8%, rgba(240,192,64,0.9), transparent),
    radial-gradient(1px 1px at 35% 20%, white, transparent),
    radial-gradient(1px 1px at 45% 15%, rgba(255,255,255,0.7), transparent),
    radial-gradient(1px 1px at 55% 30%, white, transparent),
    radial-gradient(2px 2px at 65% 5%, rgba(150,100,255,0.8), transparent),
    radial-gradient(1px 1px at 75% 18%, white, transparent),
    radial-gradient(1px 1px at 85% 12%, rgba(255,255,255,0.9), transparent),
    radial-gradient(1px 1px at 92% 25%, white, transparent),
    radial-gradient(1px 1px at 10% 35%, rgba(255,255,255,0.6), transparent),
    radial-gradient(1px 1px at 48% 28%, white, transparent);
  background-size: 400px 300px;
  animation: starsTwinkle 5s ease-in-out infinite alternate;
}

.bg-ground {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 50%;
}

.bg-castle {
  position: absolute;
  bottom: 35%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 120px;
  filter: drop-shadow(0 0 40px rgba(240,192,64,0.2));
  animation: castleGlow 4s ease-in-out infinite alternate;
}

@keyframes castleGlow {
  from { filter: drop-shadow(0 0 20px rgba(240,192,64,0.2)); }
  to { filter: drop-shadow(0 0 50px rgba(240,192,64,0.4)); }
}

.bg-lake {
  position: absolute;
  bottom: 5%;
  left: 10%; right: 10%;
  height: 30%;
  background: radial-gradient(ellipse at center, rgba(30,60,120,0.6) 0%, rgba(10,20,60,0.4) 100%);
  border-radius: 50%;
  border: 1px solid rgba(100,150,255,0.1);
}

/* ═══ SCROLLBAR ═══ */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: rgba(255,255,255,0.03); }
::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 2px; }

/* ═══ LEVEL UP SCREEN ═══ */
#levelup-screen {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.9);
