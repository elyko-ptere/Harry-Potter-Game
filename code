        hogwarts: 'POUDLARD', 'great-hall': 'GRANDE SALLE', diagon: 'CH. DE TRAVERSE',
        forest: 'FORÊT INTERDITE', hogsmeade: 'PRÉ-AU-LARD', library: 'BIBLIOTHÈQUE', dungeon: 'CACHOTS'
      };
      document.getElementById('hud-location').textContent = names[sceneId] || sceneId.toUpperCase();
    }
    // Move minimap dot
    const positions = {
      hogwarts: { left: '15%', top: '20%' },
      'great-hall': { left: '20%', top: '25%' },
      diagon: { left: '50%', top: '75%' },
      forest: { left: '40%', top: '65%' },
      hogsmeade: { left: '70%', top: '20%' },
      library: { left: '18%', top: '18%' },
      dungeon: { left: '22%', top: '30%' }
    };
