  },

  openScene(sceneId) {
    this.setScene(sceneId);
    document.getElementById('map-screen').style.display = 'none';
  },

  goBack() {
    const prev = STATE.world.prevScene || 'hogwarts';
    this.setScene(prev);
  },

  showWorld() {
    document.getElementById('map-screen').style.display = 'none';
    document.getElementById('quidditch-screen').style.display = 'none';
    document.getElementById('duel-screen').style.display = 'none';
    document.getElementById('potion-game').style.display = 'none';
    document.getElementById('profile-screen').style.display = 'none';
    document.getElementById('world').style.display = 'block';
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('nav-world').classList.add('active');
  },

  // ─ DIALOGUE SYSTEM ─────────────────────────────
  talkToNPC(npcId) {
    const npc = NPCS[npcId];
    if (!npc) return;
    dialogueNPC = npcId;
    dialogueStep = 0;
    currentDialogue = npc.dialogues[0];
    this.showDialogue(npc, currentDialogue);
    gainRelation(npcId, 2);
  },

  showDialogue(npc, dialogue) {
    if (!dialogue) { this.closeDialogue(); return; }
    const box = document.getElementById('dialogue-box');
    const text = dialogue.text.replace('%s', STATE.player.name);
    document.getElementById('dialogue-speaker').innerHTML = `${npc.icon} ${npc.name.toUpperCase()}`;
    document.getElementById('dialogue-text').textContent = '';
    box.style.display = 'block';
    document.getElementById('dialogue-continue').style.display = 'none';
    document.getElementById('dialogue-choices').innerHTML = '';

    // Typewriter effect
    let i = 0;
    const textEl = document.getElementById('dialogue-text');
    const interval = setInterval(() => {
      textEl.textContent += text[i];
      i++;
      if (i >= text.length) {
        clearInterval(interval);
        if (dialogue.choices && dialogue.choices.length > 0) {
          this.showChoices(npc, dialogue.choices);
        } else {
          document.getElementById('dialogue-continue').style.display = 'block';
        }
      }
    }, 22);
  },

  showChoices(npc, choices) {
    const container = document.getElementById('dialogue-choices');
    container.innerHTML = '';
    choices.forEach(choice => {
      const btn = document.createElement('button');
      btn.className = 'dialogue-choice';
      btn.textContent = choice.text;
      btn.onclick = () => {
        // Apply rewards
        if (choice.xp) gainXP(choice.xp > 0 ? choice.xp : 0);
        if (choice.skillXp) Object.entries(choice.skillXp).forEach(([s,v]) => gainSkillXP(s,v));
        if (choice.relation) gainRelation(dialogueNPC, choice.relation);
        if (choice.questStart) startQuest(choice.questStart);
        if (choice.questStep) advanceQuestStep(choice.questStep);
        if (choice.action === 'quidditch') { this.closeDialogue(); this.startQuidditch(); }
        if (choice.buy) this.buyFromNPC(choice.buy);

        if (choice.next) {
          // Find next dialogue
          const allDialogues = NPCS[dialogueNPC].dialogues;
          const nextD = allDialogues.find(d => d.id === choice.next) || null;
          if (nextD) { this.showDialogue(npc, nextD); }
          else { this.closeDialogue(); }
        } else {
          this.closeDialogue();
        }
      };
      container.appendChild(btn);
    });
  },

  buyFromNPC(buyData) {
    if (STATE.player.galleons >= buyData.price) {
      STATE.player.galleons -= buyData.price;
      addToInventory(null, buyData.item, buyData.name);
      notify('Achat!', `${buyData.item} ${buyData.name} acheté!`, 'success', buyData.item);
      updateHUD();
    } else {
      notify('Fonds insuffisants', 'Vous n\'avez pas assez de Gallions!', 'warning', '💰');
    }
  },

  nextDialogue() {
    this.closeDialogue();
  },

  closeDialogue() {
    document.getElementById('dialogue-box').style.display = 'none';
    currentDialogue = null;
    dialogueNPC = null;
  },

  // ─ INTERACTIONS ────────────────────────────────
  interact(id) {
    const interactions = {
      portal_platform: () => {
        this.showWorld();
        notify('Quai 9¾', 'Vous sentez la magie du quai... L\'Eclair de Poudlard part bientôt!', 'quest', '🚂');
