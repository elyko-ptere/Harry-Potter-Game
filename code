// ─── INVENTORY HELPERS ───────────────────────────
function addToInventory(itemKey, icon, name) {
  const item = itemKey ? ITEMS[itemKey] : { icon, name, qty: 1 };
  if (!item) return;

  const existing = STATE.player.inventory.find(i => i.name === (item.name || name));
  if (existing) {
    existing.qty = (existing.qty || 1) + 1;
  } else {
    STATE.player.inventory.push({ ...item, qty: 1 });
  }
  saveGame();
}

function useInventoryItem(idx) {
  const item = STATE.player.inventory[idx];
  if (!item) return;

  const itemData = Object.values(ITEMS).find(i => i.name === item.name);
  if (itemData?.effect) {
    itemData.effect();
    item.qty--;
    if (item.qty <= 0) STATE.player.inventory.splice(idx, 1);
    notify('Objet Utilisé!', `${item.icon} ${item.name} utilisé!`, 'success', item.icon);
    renderInventory();
    updateHUD();
    saveGame();
  } else {
    notify('Objet Passif', `${item.icon} ${item.name} — objet passif ou de quête`, 'quest', item.icon);
  }
}

// ─── QUEST HELPERS ───────────────────────────────
function startQuest(questId) {
  if (STATE.player.quests.includes(questId) || STATE.player.questsDone.includes(questId)) return;
  STATE.player.quests.push(questId);
  const q = QUESTS_DATA[questId];
  notify('Nouvelle Quête!', q?.name || questId, 'quest', '📜');
  saveGame();
}

function advanceQuestStep(questId) {
  if (!STATE.player.quests.includes(questId)) return;
  gainXP(30);
  notify('Quête Avancée', QUESTS_DATA[questId]?.name || questId, 'quest', '📜');
}

function completeQuest(questId) {
  const idx = STATE.player.quests.indexOf(questId);
  if (idx === -1) return;
  STATE.player.quests.splice(idx, 1);
  STATE.player.questsDone.push(questId);
  STATE.player.stats.quests++;

  const q = QUESTS_DATA[questId];
  if (q?.rewards) {
    gainXP(q.rewards.xp);
    if (q.rewards.galleons) STATE.player.galleons += q.rewards.galleons;
    if (q.rewards.item) addToInventory(null, q.rewards.item.icon, q.rewards.item.name);
    if (q.rewards.skillXp) Object.entries(q.rewards.skillXp).forEach(([s,v]) => gainSkillXP(s,v));
  }

  notify('Quête Terminée!', `${q?.name || questId}`, 'success', '🏆');
  updateHUD();
  saveGame();
}

function gainRelation(npcId, amount) {
  if (!STATE.player.relations[npcId]) STATE.player.relations[npcId] = 50;
  STATE.player.relations[npcId] = clamp(STATE.player.relations[npcId] + amount, 0, 100);
  saveGame();
}

// ─── SPELL COLOR HELPER ──────────────────────────
function getSpellColor(type) {
  const colors = { normal:'#4488ff', stun:'#ffff44', fire:'#ff4400', ice:'#44ffff',
    heal:'#44ff44', confuse:'#ff44ff', dark:'#8844cc', light:'#ffffaa' };
  return colors[type] || '#4488ff';
}

// ─── KEYBOARD INPUT ──────────────────────────────
document.addEventListener('keydown', (e) => {
  if (!STATE.game.started) return;
  const keys = {
    'i': () => Game.openInventory(),
    'k': () => Game.openSkills(),
    'q': () => Game.openQuests(),
    'm': () => Game.openMap(),
    'p': () => Game.openProfile(),
    'Escape': () => {
      Game.closeDialogue();
      ['inventory','skills','quests','shop'].forEach(p => Game.closePanel(p));
      document.getElementById('map-screen').style.display = 'none';
      document.getElementById('world').style.display = 'block';
    }
  };
  if (keys[e.key]) { e.preventDefault(); keys[e.key](); }
});

