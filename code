          notify('Accès Refusé', 'Vos sortilèges ne sont pas assez avancés... (Sortilèges niveau 20)', 'warning', '⛔');
        }
      },
      azkaban_portal: () => {
        notify('Maison Hurlante', 'De gémissements s\'échappent de la demeure... Vous frissonnez.', 'warning', '🏚️');
        gainXP(10);
      },
      cauldron_lesson: () => {
        gainXP(25); gainSkillXP('potions', 15);
        notify('Cours de Potions', 'Vous assistez au cours du Professeur Rogue!', 'quest', '🧪');
      }
    };
    if (interactions[id]) interactions[id]();
  },

  huntCreature(type) {
    const creatures = {
      centaure: { name: 'Centaure', xp: 30, skill: 'defense' },
      licorne: { name: 'Licorne', xp: 50, skill: 'botanique', item: 'pierre_lune' },
      araignee: { name: 'Araignée Géante', xp: 40, skill: 'duel' },
      thestrals: { name: 'Thestral', xp: 45, skill: 'vol' }
    };
    const c = creatures[type];
    if (!c) return;

    if (rand(0,1)) {
      gainXP(c.xp);
      gainSkillXP(c.skill, 15);
      if (c.item) addToInventory(c.item);
      notify(`Créature: ${c.name}`, `Vous avez observé une créature magique!`, 'success', '🦄');
    } else {
      STATE.player.hp = Math.max(1, STATE.player.hp - rand(5,15));
      notify(`Créature: ${c.name}`, `La créature vous a blessé! Faites attention!`, 'warning', '⚠️');
      updateHUD();
    }
  },

  readBook(type) {
    const books = {
      histoire: { xp: 20, skill: 'sortileges', msg: 'Histoire des Quatre Fondateurs de Poudlard...' },
      sortileges: { xp: 25, skill: 'sortileges', msg: 'Nouvelles incantations découvertes!' },
      bestiaire: { xp: 20, skill: 'botanique', msg: 'Créatures fantastiques et où les trouver...' }
    };
    const b = books[type];
    gainXP(b.xp);
    gainSkillXP(b.skill, 12);
    notify('Lecture', b.msg, 'quest', '📖');
  },

  // ─ DUEL SYSTEM ─────────────────────────────────
  startDuel(enemyIdx) {
    const enemy = enemyIdx !== undefined ? ENEMIES[enemyIdx] : ENEMIES[rand(0, ENEMIES.length-1)];
    STATE.duel = {
      active: true,
      enemy: { ...enemy },
      playerHp: STATE.player.hp,
      enemyHp: enemy.hp
    };

    document.getElementById('world').style.display = 'none';
    document.getElementById('duel-screen').style.display = 'flex';
    document.getElementById('duel-player-name').textContent = STATE.player.name.toUpperCase();
    document.getElementById('duel-enemy-name').textContent = enemy.name.toUpperCase();
    document.getElementById('duel-player-fig').textContent = STATE.player.avatar;
    document.getElementById('duel-enemy-fig').textContent = enemy.icon;
    this.updateDuelBars();
    this.buildSpellButtons();
    document.getElementById('duel-log').innerHTML = `<div class="duel-log-entry system">⚔️ Duel commencé contre ${enemy.name}! Choisissez votre sort!</div>`;
  },

  updateDuelBars() {
    const d = STATE.duel;
    const phpct = d.playerHp / STATE.player.hpMax * 100;
    const ehpct = d.enemyHp / d.enemy.maxHp * 100;
    document.getElementById('duel-player-hp').style.width = phpct + '%';
    document.getElementById('duel-enemy-hp').style.width = ehpct + '%';
    document.getElementById('duel-player-hp-text').textContent = `${d.playerHp}/${STATE.player.hpMax}`;
    document.getElementById('duel-enemy-hp-text').textContent = `${d.enemyHp}/${d.enemy.maxHp}`;
  },

  buildSpellButtons() {
    const container = document.getElementById('duel-spells');
    container.innerHTML = '';
    SPELLS.forEach((spell, idx) => {
      const btn = document.createElement('div');
      btn.className = 'duel-spell';
      btn.innerHTML = `<span class="spell-icon">${spell.icon}</span>
        <div class="spell-name">${spell.name}</div>
        <div class="spell-mp">💙 ${spell.mp}</div>`;
      btn.onclick = () => this.castSpell(idx);
      container.appendChild(btn);
    });
  },

  castSpell(spellIdx) {
    if (!STATE.duel.active) return;
    const spell = SPELLS[spellIdx];
    if (STATE.player.mp < spell.mp) {
      notify('Mana insuffisant', `Vous n'avez pas assez de mana pour ${spell.name}!`, 'warning', '💙');
      return;
    }
    STATE.player.mp -= spell.mp;

    let dmg = rand(spell.dmg[0], spell.dmg[1]);
    let logText = '';

    if (spell.type === 'heal') {
      const heal = Math.abs(dmg);
      STATE.duel.playerHp = Math.min(STATE.player.hpMax, STATE.duel.playerHp + heal);
      logText = `✨ Vous lancez ${spell.name} — Soin de ${heal} HP!`;
    } else {
      const bonus = Math.floor((STATE.player.skills.sortileges || 0) / 20);
      dmg += bonus;
      STATE.duel.enemyHp -= dmg;
      logText = `${spell.icon} Vous lancez ${spell.name} — ${dmg} dégâts!`;
    }

    // Flash beam
    const beam = document.getElementById('duel-beam');
    beam.classList.add('active');
    beam.style.background = `linear-gradient(90deg, ${getSpellColor(spell.type)}, #ff4444)`;
    setTimeout(() => beam.classList.remove('active'), 300);

    this.addDuelLog(logText, 'player');
    this.updateDuelBars();
    updateHUD();

    if (STATE.duel.enemyHp <= 0) {
      this.winDuel();
      return;
    }

    // Enemy turn (delayed)
    setTimeout(() => this.enemyTurn(), 800);
  },

  enemyTurn() {
    if (!STATE.duel.active) return;
    const enemy = STATE.duel.enemy;
    const dmg = rand(enemy.dmg[0], enemy.dmg[1]);
    const defBonus = Math.floor((STATE.player.skills.defense || 0) / 25);
    const finalDmg = Math.max(1, dmg - defBonus);
    STATE.duel.playerHp -= finalDmg;
    this.addDuelLog(`${enemy.icon} ${enemy.name} attaque — ${finalDmg} dégâts!`, 'enemy');
    this.updateDuelBars();

    if (STATE.duel.playerHp <= 0) {
      this.loseDuel();
    }
  },

  winDuel() {
    STATE.duel.active = false;
    const xpGain = STATE.duel.enemy.xp;
    const goldGain = rand(5, 20);
    STATE.player.hp = STATE.duel.playerHp;
    STATE.player.galleons += goldGain;
    STATE.player.stats.duels++;
    gainXP(xpGain);
    gainSkillXP('duel', 20);
    this.addDuelLog(`🏆 VICTOIRE! +${xpGain} XP, +${goldGain} Gallions!`, 'system');
    setTimeout(() => {
      this.closeDuel();
      notify('Victoire!', `Vous avez vaincu ${STATE.duel?.enemy?.name || 'l\'adversaire'}! +${xpGain}XP`, 'success', '🏆');
    }, 1500);
    updateHUD();
    saveGame();
  },

  loseDuel() {
    STATE.duel.active = false;
    STATE.player.hp = 5;
    STATE.player.galleons = Math.max(0, STATE.player.galleons - 10);
    gainXP(15);
    gainSkillXP('defense', 10);
    this.addDuelLog(`💀 Défaite... -10 Gallions. Reposez-vous à l'infirmerie.`, 'system');
    setTimeout(() => {
      this.closeDuel();
      notify('Défaite', 'Vous avez perdu le duel... Recuperez-vous!', 'warning', '💔');
    }, 1500);
    updateHUD();
    saveGame();
  },

  addDuelLog(text, type) {
    const log = document.getElementById('duel-log');
    const entry = document.createElement('div');
    entry.className = `duel-log-entry ${type}`;
    entry.textContent = text;
    log.appendChild(entry);
    log.scrollTop = log.scrollHeight;
  },

  closeDuel() {
    document.getElementById('duel-screen').style.display = 'none';
    document.getElementById('world').style.display = 'block';
    STATE.duel.active = false;
  },

  // ─ POTIONS MINI-GAME ───────────────────────────
  openPotions() {
    const recipe = POTION_RECIPES[rand(0, POTION_RECIPES.length-1)];
    STATE.potion = { active: true, recipe, added: [] };

    document.getElementById('world').style.display = 'none';
    document.getElementById('potion-game').style.display = 'flex';
    document.getElementById('potion-recipe-name').textContent = recipe.icon + ' ' + recipe.name;
    document.getElementById('potion-result').textContent = '';

    // Build required ingredients display
    const reqEl = document.getElementById('potion-required');
    reqEl.innerHTML = recipe.required.map(r => `<div class="potion-ingredient" data-req="${r}">${r} <span style="font-size:10px;opacity:0.6">${r}</span></div>`).join('');

    // Build available slots
    const slotsEl = document.getElementById('potion-slots');
    slotsEl.innerHTML = '';
    const shuffled = [...POTION_INGREDIENTS].sort(() => Math.random()-0.5).slice(0, 12);
    shuffled.forEach(ing => {
      const slot = document.createElement('div');
      slot.className = 'potion-slot';
      slot.innerHTML = `${ing}<div class="potion-slot-name">${ing}</div>`;
      slot.onclick = () => this.addIngredient(ing, slot);
      slotsEl.appendChild(slot);
    });
  },

  addIngredient(ing, slotEl) {
    if (STATE.potion.added.includes(ing)) {
      notify('Déjà ajouté', 'Cet ingrédient est déjà dans le chaudron!', 'warning', '⚗️');
      return;
    }
    STATE.potion.added.push(ing);
    slotEl.style.opacity = '0.4';
    slotEl.style.pointerEvents = 'none';

    // Update required display
    const reqEls = document.querySelectorAll(`[data-req="${ing}"]`);
    reqEls.forEach(el => el.classList.add('added'));

    notify('Ingrédient ajouté!', `${ing} ajouté au chaudron!`, 'success', '⚗️');
  },

  brewPotion() {
    const recipe = STATE.potion.recipe;
    const required = recipe.required;
    const allAdded = required.every(r => STATE.potion.added.includes(r));

    if (allAdded) {
      const result = document.getElementById('potion-result');
      result.textContent = `✅ Excellente potion de ${recipe.name} préparée!`;
      result.style.color = '#00cc66';
      gainXP(recipe.reward.xp);
      gainSkillXP('potions', recipe.reward.skillXp);
      if (recipe.reward.item) addToInventory(recipe.reward.item);
      STATE.player.stats.potions++;
      notify('Potion Réussie!', `${recipe.icon} ${recipe.name} créée!`, 'success', '⚗️');
      // Advance quest if applicable
      if (STATE.player.quests.includes('side_potion')) {
        completeQuest('side_potion');
      }
      saveGame();
    } else {
      const missing = required.filter(r => !STATE.potion.added.includes(r));
      document.getElementById('potion-result').textContent = `❌ Ingrédients manquants: ${missing.join(', ')}`;
      document.getElementById('potion-result').style.color = '#ff4444';
    }
  },

  closePotions() {
    document.getElementById('potion-game').style.display = 'none';
    document.getElementById('world').style.display = 'block';
    STATE.potion.active = false;
  },

  // ─ QUIDDITCH ───────────────────────────────────
  startQuidditch() {
    document.getElementById('world').style.display = 'none';
    document.getElementById('quidditch-screen').style.display = 'flex';
    STATE.quidditch = { score: [0,0], timer: 120, interval: null, playerX: 45, playerY: 45 };
    document.getElementById('quidditch-score').textContent = '0 — 0';
    document.getElementById('quidditch-timer').textContent = '⏱️ 120s';
    document.getElementById('quidditch-msg').textContent = 'Attrapez le Vif d\'Or (✨) ou marquez des buts!';

    STATE.quidditch.interval = setInterval(() => {
      STATE.quidditch.timer--;
      document.getElementById('quidditch-timer').textContent = `⏱️ ${STATE.quidditch.timer}s`;

      // Move snitch randomly
      const snitch = document.getElementById('q-snitch');
      const newX = clamp(rand(5,90), 5, 90);
      const newY = clamp(rand(5,85), 5, 85);
      snitch.style.left = newX + '%';
      snitch.style.top = newY + '%';

      // Enemy might score
      if (rand(0,20) === 0) {
        STATE.quidditch.score[1]++;
        document.getElementById('quidditch-score').textContent = `${STATE.quidditch.score[0]} — ${STATE.quidditch.score[1]}`;
        document.getElementById('quidditch-msg').textContent = "⚠️ L'équipe adverse marque!";
      }

      if (STATE.quidditch.timer <= 0) {
        clearInterval(STATE.quidditch.interval);
        this.endQuidditch(false);
      }
    }, 1000);
  },

  quidditchAction(dir) {
    const player = document.getElementById('q-player');
    const snitch = document.getElementById('q-snitch');
    let x = STATE.quidditch.playerX;
    let y = STATE.quidditch.playerY;
    const step = 12;

    if (dir === 'left') x = clamp(x - step, 2, 92);
    if (dir === 'right') x = clamp(x + step, 2, 92);
    if (dir === 'up') y = clamp(y - step, 2, 88);
    if (dir === 'down') y = clamp(y + step, 2, 88);

    STATE.quidditch.playerX = x;
    STATE.quidditch.playerY = y;
    player.style.left = x + '%';
    player.style.top = y + '%';

    gainSkillXP('vol', 2);

    // Check snitch collision
    const sx = parseFloat(snitch.style.left);
    const sy = parseFloat(snitch.style.top);
    if (Math.abs(x - sx) < 15 && Math.abs(y - sy) < 15) {
      clearInterval(STATE.quidditch.interval);
      document.getElementById('quidditch-msg').textContent = '🏆 Vous avez attrapé le Vif d\'Or!';
      STATE.quidditch.score[0] += 150;
      document.getElementById('quidditch-score').textContent = `${STATE.quidditch.score[0]} — ${STATE.quidditch.score[1]}`;
      setTimeout(() => this.endQuidditch(true), 1500);
      return;
    }

    // Random scoring
    if (rand(0,4) === 0) {
      STATE.quidditch.score[0] += 10;
      document.getElementById('quidditch-score').textContent = `${STATE.quidditch.score[0]} — ${STATE.quidditch.score[1]}`;
      document.getElementById('quidditch-msg').textContent = '⚡ But marqué! +10 points!';
    }
  },

  endQuidditch(caughtSnitch) {
    clearInterval(STATE.quidditch.interval);
    const score = STATE.quidditch.score;
    const won = score[0] > score[1] || caughtSnitch;
    const xpGain = won ? 100 : 40;
    const goldGain = won ? 30 : 5;

    gainXP(xpGain);
    gainSkillXP('vol', 30);
    STATE.player.galleons += goldGain;
    updateHUD();
    saveGame();

    if (won) {
      notify('Victoire au Quidditch!', `Score: ${score[0]}-${score[1]} — +${xpGain}XP, +${goldGain}G!`, 'success', '🏆');
    } else {
      notify('Match Terminé', `Score: ${score[0]}-${score[1]} — +${xpGain}XP`, 'quest', '🦅');
    }
    setTimeout(() => this.closeQuidditch(), 2000);
  },

  closeQuidditch() {
    if (STATE.quidditch.interval) clearInterval(STATE.quidditch.interval);
    document.getElementById('quidditch-screen').style.display = 'none';
    document.getElementById('world').style.display = 'block';
  },

  // ─ SHOP ─────────────────────────────────────────
  openShop(shopKey = 'default') {
    currentShopKey = shopKey;
    const shop = SHOPS[shopKey];
    document.getElementById('shop-title').textContent = shop.title;
    document.getElementById('shop-galleons').textContent = STATE.player.galleons;

    const grid = document.getElementById('shop-items-grid');
    grid.innerHTML = '';
    shop.items.forEach(itemKey => {
      const item = ITEMS[itemKey];
      if (!item) return;
      const div = document.createElement('div');
      div.className = 'shop-item';
      div.innerHTML = `
        <div class="shop-item-header">
          <span class="shop-item-icon">${item.icon}</span>
          <span class="shop-item-name">${item.name}</span>
        </div>
        <div class="shop-item-desc">${item.desc}</div>
        <div class="shop-item-price">🥇 ${item.price} Gallions</div>`;
      div.onclick = () => this.purchaseItem(itemKey);
      grid.appendChild(div);
    });

    document.getElementById('panel-shop').classList.add('open');
  },

  purchaseItem(itemKey) {
    const item = ITEMS[itemKey];
    if (!item) return;
    if (STATE.player.galleons < item.price) {
      notify('Fonds insuffisants', `Vous avez besoin de ${item.price} Gallions!`, 'warning', '💰');
      return;
    }
    STATE.player.galleons -= item.price;
    addToInventory(itemKey);
    document.getElementById('shop-galleons').textContent = STATE.player.galleons;
    document.getElementById('inv-galleons').textContent = STATE.player.galleons;
    document.getElementById('hud-galleons').textContent = '💰 ' + STATE.player.galleons;
    notify('Achat!', `${item.icon} ${item.name} acheté!`, 'success', item.icon);
    if (item.effect) item.effect();
    saveGame();
  },

  openShopGringotts() { this.openShop('gringotts'); },
  openShopOllivander() { this.openShop('ollivander'); },
  openShopZonon() { this.openShop('zonon'); },
  openShopHoneydukes() { this.openShop('honeydukes'); },
  openShopHogHead() { this.openShop('hoghead'); },
  openShopThreeBroomsticks() { this.openShop('threebroomsticks'); },
  openShopPotionIngredients() { this.openShop('potion_ingredients'); },

  // ─ PANELS ────────────────────────────────────────
  openInventory() {
    document.getElementById('inv-galleons').textContent = STATE.player.galleons;
    document.getElementById('inv-mornilles').textContent = STATE.player.mornilles;
    document.getElementById('inv-noises').textContent = STATE.player.noises;
    renderInventory();
    document.getElementById('panel-inventory').classList.add('open');
  },

  openSkills() {
    document.getElementById('skill-year').textContent = STATE.player.year;
    document.getElementById('skill-level-display').textContent = STATE.player.level;
    renderSkills();
    document.getElementById('panel-skills').classList.add('open');
  },

  openQuests() {
    renderQuests();
    document.getElementById('panel-quests').classList.add('open');
  },

  openProfile() {
    const p = STATE.player;
    document.getElementById('profile-avatar-display').textContent = p.avatar;
    document.getElementById('profile-name').textContent = p.name;
    const h = HOUSES[p.house];
    document.getElementById('profile-house').textContent = `${h?.badge || '🦁'} ${h?.name || 'Gryffondor'} — ${p.year}ème Année`;
    document.getElementById('profile-wand').textContent = `${p.wand} ${p.wandName} | ${p.pet} ${p.petName}`;
    document.getElementById('prof-level').textContent = p.level;
    document.getElementById('prof-xp').textContent = p.xpTotal;
    document.getElementById('prof-gold').textContent = p.galleons;
    document.getElementById('prof-quests').textContent = p.questsDone.length;
    document.getElementById('prof-duels').textContent = p.stats.duels;
    document.getElementById('prof-potions').textContent = p.stats.potions;
    renderRelations();
    document.getElementById('profile-screen').style.display = 'flex';
    document.getElementById('world').style.display = 'none';
  },

  closeProfile() {
    document.getElementById('profile-screen').style.display = 'none';
    document.getElementById('world').style.display = 'block';
  },

  closePanel(id) {
    document.getElementById('panel-' + id).classList.remove('open');
  },

  openMap() {
    renderMap();
    document.getElementById('world').style.display = 'none';
    document.getElementById('map-screen').style.display = 'flex';
  },

  closeMap() {
    document.getElementById('map-screen').style.display = 'none';
    document.getElementById('world').style.display = 'block';
  },

  closeLevelUp() {
    document.getElementById('levelup-screen').style.display = 'none';
  }
};

// ─── RENDER FUNCTIONS ────────────────────────────
function renderInventory() {
  const grid = document.getElementById('inventory-grid');
  grid.innerHTML = '';
  const totalSlots = 20;
  const inv = STATE.player.inventory;

  for (let i = 0; i < totalSlots; i++) {
    const slot = document.createElement('div');
    if (i < inv.length) {
      const item = inv[i];
      slot.className = 'inv-slot occupied';
      slot.innerHTML = `<span class="inv-slot-icon">${item.icon}</span>
        <span class="inv-slot-name">${item.name}</span>
        ${item.qty > 1 ? `<span class="inv-slot-qty">×${item.qty}</span>` : ''}`;
      slot.title = item.desc || item.name;
      slot.onclick = () => useInventoryItem(i);
    } else {
      slot.className = 'inv-slot';
    }
    grid.appendChild(slot);
  }
}

function renderSkills() {
  const grid = document.getElementById('skills-grid');
  grid.innerHTML = '';
  const skillIcons = { sortileges:'✨', potions:'⚗️', duel:'⚔️', botanique:'🌿', vol:'🧹', defense:'🛡️' };
  const skillNames = { sortileges:'Sortilèges', potions:'Potions', duel:'Duel', botanique:'Botanique', vol:'Vol en Balai', defense:'Défense' };

  Object.entries(STATE.player.skills).forEach(([key, val]) => {
    const div = document.createElement('div');
    div.className = 'skill-item';
    const level = Math.floor(val / 10) + 1;
    div.innerHTML = `
      <div class="skill-header">
        <span class="skill-name">${skillIcons[key]} ${skillNames[key]}</span>
        <span class="skill-level">Nv${level}</span>
      </div>
      <div class="skill-bar"><div class="skill-bar-fill" style="width:${val}%"></div></div>
      <div style="font-size:10px;color:var(--parchment-dark);margin-top:4px">${val}/100 XP</div>`;
    grid.appendChild(div);
  });
}

function renderQuests() {
  const activeList = document.getElementById('quests-list');
  const doneList = document.getElementById('quests-done-list');
  activeList.innerHTML = '';
  doneList.innerHTML = '';

  if (STATE.player.quests.length === 0) {
    activeList.innerHTML = '<div style="color:var(--parchment-dark);font-style:italic;padding:12px">Aucune quête active. Parlez aux PNJ!</div>';
  }

  STATE.player.quests.forEach(qId => {
    const q = QUESTS_DATA[qId];
    if (!q) return;
    const div = document.createElement('div');
    div.className = 'quest-item active';
    const progress = rand(20, 80); // simplified
    div.innerHTML = `
      <div class="quest-header">
        <span class="quest-name">${q.name}</span>
        <span class="quest-badge ${q.type}">${q.type === 'main' ? 'PRINCIPALE' : 'SECONDAIRE'}</span>
      </div>
      <div class="quest-desc">${q.desc}</div>
      <div style="font-size:11px;color:var(--gold);margin-top:6px">
        ${q.steps.map((s,i) => `<div style="padding:2px 0">• ${s}</div>`).join('')}
      </div>
      <div style="font-size:11px;color:var(--parchment-dark);margin-top:6px">
        Récompenses: ${q.rewards.xp} XP${q.rewards.galleons ? ', '+q.rewards.galleons+' Gallions' : ''}
      </div>`;
    activeList.appendChild(div);
  });

  STATE.player.questsDone.forEach(qId => {
    const q = QUESTS_DATA[qId];
    if (!q) return;
    const div = document.createElement('div');
    div.className = 'quest-item';
    div.innerHTML = `
      <div class="quest-header">
        <span class="quest-name">${q.name}</span>
        <span class="quest-badge done">TERMINÉE</span>
      </div>
      <div class="quest-desc">${q.desc}</div>`;
    doneList.appendChild(div);
  });
}

