.inv-gold {
  background: rgba(240,192,64,0.1);
  border: 1px solid var(--gold-dim);
  border-radius: 6px;
  padding: 12px 16px;
  display: flex;
  gap: 20px;
  margin-bottom: 16px;
}

.inv-currency {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-ui);
  font-size: 14px;
  color: var(--gold);
}

/* ═══ SKILLS ═══ */
.skills-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.skill-item {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(240,192,64,0.15);
  border-radius: 6px;
  padding: 12px;
}

.skill-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.skill-name {
  font-family: var(--font-ui);
  font-size: 11px;
  color: var(--parchment);
  display: flex;
  align-items: center;
  gap: 6px;
}

.skill-level {
  font-family: var(--font-ui);
  font-size: 11px;
  color: var(--gold);
}

.skill-bar {
  height: 6px;
  background: rgba(255,255,255,0.08);
  border-radius: 3px;
  overflow: hidden;
}

.skill-bar-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, var(--gold-dim), var(--gold));
  transition: width 0.8s ease;
}

/* ═══ QUESTS ═══ */
.quest-item {
  border: 1px solid rgba(240,192,64,0.2);
  border-radius: 6px;
  padding: 14px;
  margin-bottom: 10px;
  cursor: pointer;
  transition: all 0.3s;
  background: rgba(255,255,255,0.02);
}

.quest-item:hover { border-color: var(--gold-dim); background: rgba(240,192,64,0.05); }

.quest-item.active { border-color: var(--gold); background: rgba(240,192,64,0.08); }

.quest-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 6px;
}

.quest-name {
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--gold);
}

.quest-badge {
  font-size: 10px;
  font-family: var(--font-ui);
  padding: 2px 8px;
  border-radius: 3px;
  letter-spacing: 1px;
}

.quest-badge.main { background: rgba(200,50,50,0.3); color: #ff8888; border: 1px solid rgba(200,50,50,0.4); }
.quest-badge.side { background: rgba(50,100,200,0.3); color: #88aaff; border: 1px solid rgba(50,100,200,0.4); }
.quest-badge.done { background: rgba(50,150,50,0.3); color: #88ff88; border: 1px solid rgba(50,150,50,0.4); }

.quest-desc {
  font-size: 13px;
  color: var(--parchment-dark);
  line-height: 1.5;
}

.quest-progress {
  margin-top: 8px;
  height: 4px;
  background: rgba(255,255,255,0.08);
  border-radius: 2px;
  overflow: hidden;
}

.quest-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--teal), var(--teal-bright));
  border-radius: 2px;
  transition: width 0.5s;
}

/* ═══ DIALOGUE SYSTEM ═══ */
#dialogue-box {
  position: fixed;
  bottom: 80px; left: 16px; right: 16px;
  background: rgba(5,2,12,0.98);
  border: 1px solid var(--gold-dim);
  border-radius: 8px;
  padding: 20px 24px;
  z-index: 150;
  display: none;
  box-shadow: 0 -4px 30px rgba(240,192,64,0.1);
}

#dialogue-box::before {
  content: '';
  position: absolute;
  top: -1px; left: 15%; right: 15%;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.dialogue-speaker {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--gold);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.dialogue-text {
  font-size: 15px;
  color: var(--parchment);
  line-height: 1.7;
  font-style: italic;
  margin-bottom: 14px;
  min-height: 40px;
}

.dialogue-choices {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.dialogue-choice {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(240,192,64,0.2);
  border-radius: 4px;
  padding: 10px 14px;
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--white);
  text-align: left;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  gap: 8px;
}

.dialogue-choice::before { content: '◆'; color: var(--gold-dim); font-size: 10px; }

.dialogue-choice:hover {
  border-color: var(--gold);
  background: rgba(240,192,64,0.08);
  transform: translateX(4px);
}

.dialogue-continue {
  text-align: right;
  font-size: 11px;
  font-family: var(--font-ui);
  color: var(--gold-dim);
  cursor: pointer;
  letter-spacing: 2px;
  animation: blink 1s ease-in-out infinite alternate;
}

@keyframes blink { from { opacity: 0.4; } to { opacity: 1; } }

/* ═══ DUEL SYSTEM ═══ */
#duel-screen {
  position: fixed;
  inset: 70px 0 70px;
  background: radial-gradient(ellipse at center, #1a001a 0%, #0a0010 100%);
  display: none;
  flex-direction: column;
  z-index: 300;
  padding: 20px;
}

.duel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.duel-combatant {
  text-align: center;
  flex: 1;
}

.duel-name {
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--gold);
  margin-bottom: 6px;
}

.duel-hp-bar {
  height: 12px;
  background: rgba(255,255,255,0.1);
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
}

.duel-hp-fill {
  height: 100%;
  border-radius: 6px;
  transition: width 0.5s ease;
}

.player-hp { background: linear-gradient(90deg, #cc2222, #ff4444); }
.enemy-hp { background: linear-gradient(90deg, #224488, #4488ff); }

.duel-vs {
  font-family: var(--font-title);
  font-size: 24px;
  color: var(--gold);
  text-shadow: var(--glow-gold);
  padding: 0 20px;
}

.duel-arena {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 60px;
  margin: 20px 0;
}

.duel-figure {
  font-size: 60px;
  animation: duelFloat 2s ease-in-out infinite alternate;
}

@keyframes duelFloat {
  from { transform: translateY(0); }
  to { transform: translateY(-12px); }
}

.duel-figure.enemy { animation-delay: 0.5s; }

.duel-beam {
  width: 100px; height: 4px;
  background: linear-gradient(90deg, #4444ff, #ff4444);
  border-radius: 2px;
  box-shadow: 0 0 20px rgba(100,100,255,0.8);
  transform: scaleX(0);
  transition: transform 0.3s;
}

.duel-beam.active { transform: scaleX(1); }

.duel-log {
  height: 80px;
  overflow-y: auto;
  padding: 10px;
  background: rgba(0,0,0,0.4);
  border: 1px solid rgba(240,192,64,0.1);
  border-radius: 6px;
  margin-bottom: 16px;
  font-size: 13px;
  font-style: italic;
  color: var(--parchment);
}

.duel-log-entry {
  padding: 2px 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.duel-log-entry.player { color: #88aaff; }
.duel-log-entry.enemy { color: #ff8888; }
.duel-log-entry.system { color: var(--gold); }

.duel-spells {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.duel-spell {
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--gold-dim);
  border-radius: 6px;
  padding: 10px 6px;
  cursor: pointer;
  text-align: center;
  transition: all 0.3s;
  position: relative;
}

.duel-spell:hover {
  background: rgba(240,192,64,0.1);
  border-color: var(--gold);
  transform: scale(1.05);
}

.duel-spell:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.spell-icon { font-size: 20px; display: block; margin-bottom: 4px; }
.spell-name { font-size: 10px; font-family: var(--font-ui); color: var(--gold); letter-spacing: 0.5px; }
.spell-mp { font-size: 9px; color: var(--parchment-dark); margin-top: 2px; }

/* ═══ SHOP ═══ */
.shop-items {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.shop-item {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(240,192,64,0.15);
  border-radius: 6px;
  padding: 14px;
  cursor: pointer;
  transition: all 0.3s;
}

.shop-item:hover {
  border-color: var(--gold-dim);
  background: rgba(240,192,64,0.05);
  transform: scale(1.02);
}

.shop-item-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 6px;
}

.shop-item-icon { font-size: 24px; }

.shop-item-name {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--gold);
}

.shop-item-desc {
  font-size: 12px;
  color: var(--parchment-dark);
  margin-bottom: 8px;
}

.shop-item-price {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--gold-bright);
  display: flex;
  align-items: center;
  gap: 4px;
}

/* ═══ POTION MINI-GAME ═══ */
#potion-game {
  position: fixed;
  inset: 70px 0 70px;
  background: radial-gradient(ellipse at center, #001a10 0%, #000a08 100%);
  display: none;
  flex-direction: column;
  align-items: center;
  padding: 24px;
  z-index: 300;
}

.potion-cauldron {
  font-size: 80px;
  animation: cauldronBubble 1s ease-in-out infinite alternate;
  filter: drop-shadow(0 0 20px rgba(0,200,100,0.5));
}

@keyframes cauldronBubble {
  from { transform: scale(1) rotate(-2deg); }
  to { transform: scale(1.05) rotate(2deg); }
}

.potion-recipe {
  background: rgba(5,20,10,0.9);
  border: 1px solid rgba(0,200,100,0.3);
  border-radius: 6px;
  padding: 16px 24px;
  margin: 16px 0;
  text-align: center;
  max-width: 500px;
  width: 100%;
}

.potion-recipe-title {
  font-family: var(--font-ui);
  font-size: 14px;
  color: #00cc66;
  letter-spacing: 2px;
  margin-bottom: 10px;
}

.potion-ingredients {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.potion-ingredient {
  background: rgba(0,100,50,0.2);
  border: 1px solid rgba(0,200,100,0.2);
  border-radius: 4px;
  padding: 8px 12px;
  font-size: 13px;
  color: var(--parchment);
  display: flex;
  align-items: center;
  gap: 6px;
}

.potion-ingredient.added {
  border-color: #00cc66;
  background: rgba(0,200,100,0.15);
  color: #88ffcc;
}

.potion-slots {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8px;
  max-width: 480px;
  width: 100%;
  margin: 16px 0;
}

.potion-slot {
  aspect-ratio: 1;
  background: rgba(0,100,50,0.1);
  border: 1px solid rgba(0,200,100,0.2);
  border-radius: 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s;
  font-size: 20px;
  padding: 8px;
}

.potion-slot:hover {
  border-color: #00cc66;
  background: rgba(0,200,100,0.1);
  transform: scale(1.08);
}

.potion-slot-name {
  font-size: 8px;
  font-family: var(--font-ui);
  color: rgba(0,200,100,0.7);
  margin-top: 2px;
  text-align: center;
}

.potion-btn {
  font-family: var(--font-ui);
  font-size: 13px;
  padding: 12px 32px;
  background: linear-gradient(135deg, #005530, #00aa60);
  border: 1px solid #00cc66;
  border-radius: 4px;
  color: white;
  cursor: pointer;
  letter-spacing: 2px;
  transition: all 0.3s;
}

.potion-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 0 20px rgba(0,200,100,0.4);
}

/* ═══ MAP SCREEN ═══ */
#map-screen {
  position: fixed;
  inset: 70px 0 70px;
  display: none;
  background: radial-gradient(ellipse at center, #0a0820 0%, #050410 100%);
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
  z-index: 200;
}

.map-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  max-width: 600px;
  width: 100%;
}

.map-location {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(240,192,64,0.2);
  border-radius: 8px;
  padding: 16px 12px;
  text-align: center;
  cursor: pointer;
  transition: all 0.4s;
  position: relative;
  overflow: hidden;
}

.map-location::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, rgba(240,192,64,0.05) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s;
}

.map-location:hover::before { opacity: 1; }

.map-location:hover {
  border-color: var(--gold);
  transform: scale(1.04);
  box-shadow: 0 4px 20px rgba(240,192,64,0.15);
}

.map-location.locked {
  opacity: 0.4;
  cursor: not-allowed;
}

.map-location.current {
  border-color: var(--gold);
  box-shadow: 0 0 20px rgba(240,192,64,0.2);
}

.map-loc-icon { font-size: 32px; display: block; margin-bottom: 6px; }
.map-loc-name {
  font-family: var(--font-ui);
  font-size: 11px;
  color: var(--gold);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.map-loc-desc {
  font-size: 11px;
  color: var(--parchment-dark);
  margin-top: 4px;
}

.map-loc-lock {
  position: absolute;
  top: 8px; right: 8px;
  font-size: 12px;
  opacity: 0.5;
}

/* ═══ NOTIFICATIONS ═══ */
#notifications {
  position: fixed;
  top: 80px; left: 16px;
  z-index: 500;
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-width: 280px;
}

.notif {
  background: rgba(5,2,12,0.97);
  border: 1px solid var(--gold-dim);
  border-radius: 6px;
  padding: 12px 16px;
  font-size: 13px;
  color: var(--parchment);
  display: flex;
  align-items: center;
  gap: 10px;
  animation: notifSlide 0.4s ease-out, notifFade 0.4s ease-in 3s forwards;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
}

@keyframes notifSlide {
  from { transform: translateX(-100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes notifFade {
  from { opacity: 1; }
  to { opacity: 0; pointer-events: none; }
}

.notif-icon { font-size: 18px; }
.notif-text { flex: 1; }
.notif-title { font-family: var(--font-ui); font-size: 11px; color: var(--gold); margin-bottom: 2px; }

.notif.xp { border-color: var(--gold-dim); }
.notif.quest { border-color: rgba(100,200,255,0.4); }
.notif.warning { border-color: rgba(255,100,100,0.4); }
.notif.success { border-color: rgba(100,255,100,0.4); }

/* ═══ NPC ═══ */
.npc {
  position: absolute;
  cursor: pointer;
  transition: transform 0.3s;
  text-align: center;
  user-select: none;
}

.npc:hover { transform: scale(1.15); }

.npc-sprite {
  font-size: 32px;
  display: block;
  animation: npcFloat 2.5s ease-in-out infinite alternate;
}

.npc-name {
  font-size: 9px;
  font-family: var(--font-ui);
  color: var(--gold);
  display: block;
  text-shadow: 0 1px 4px black;
  background: rgba(0,0,0,0.6);
  border-radius: 3px;
  padding: 1px 4px;
  margin-top: 2px;
}

@keyframes npcFloat {
  from { transform: translateY(0); }
  to { transform: translateY(-6px); }
}

/* ═══ PLAYER SPRITE ═══ */
#player {
  position: absolute;
  text-align: center;
  z-index: 10;
  pointer-events: none;
  transition: left 0.3s, top 0.3s;
}

#player-sprite {
  font-size: 36px;
  display: block;
  filter: drop-shadow(0 0 8px rgba(240,192,64,0.5));
}

.player-name-tag {
  font-size: 9px;
  font-family: var(--font-ui);
  color: var(--gold);
  background: rgba(0,0,0,0.7);
  border-radius: 3px;
  padding: 1px 6px;
  display: block;
  text-align: center;
  white-space: nowrap;
}

/* ═══ SCENE ELEMENTS ═══ */
.scene-element {
  position: absolute;
  cursor: pointer;
  transition: transform 0.3s, filter 0.3s;
  text-align: center;
  font-size: 40px;
}

.scene-element:hover {
  transform: scale(1.1);
  filter: brightness(1.3);
}

.scene-label {
  font-size: 10px;
  font-family: var(--font-ui);
  color: var(--gold-dim);
  text-align: center;
  display: block;
  background: rgba(0,0,0,0.6);
  border-radius: 3px;
  padding: 1px 4px;
}

/* ═══ DAY/NIGHT OVERLAY ═══ */
#daynight {
  position: fixed;
  inset: 70px 0 70px;
  pointer-events: none;
  z-index: 50;
  transition: background 30s linear;
  mix-blend-mode: multiply;
}

/* ═══ WEATHER EFFECTS ═══ */
#weather-overlay {
  position: fixed;
  inset: 70px 0 70px;
  pointer-events: none;
  z-index: 51;
  overflow: hidden;
}

.rain-drop {
  position: absolute;
  top: -20px;
  width: 2px;
  height: 15px;
  background: linear-gradient(180deg, transparent, rgba(150,200,255,0.6));
  border-radius: 1px;
  animation: rainFall linear infinite;
}

@keyframes rainFall {
  from { transform: translateY(-20px) rotate(15deg); }
  to { transform: translateY(100vh) rotate(15deg); }
}

.snow-flake {
  position: absolute;
  top: -20px;
  color: white;
  font-size: 12px;
  animation: snowFall linear infinite;
}

@keyframes snowFall {
  from { transform: translateY(-20px) rotate(0deg); }
  to { transform: translateY(100vh) rotate(720deg); }
}

.magic-particle {
  position: absolute;
  width: 4px; height: 4px;
  border-radius: 50%;
  animation: magicFloat linear infinite;
  pointer-events: none;
}

@keyframes magicFloat {
  0% { transform: translateY(100%) rotate(0deg); opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
}

/* ═══ QUIDDITCH ═══ */
#quidditch-screen {
  position: fixed;
  inset: 70px 0 70px;
  background: radial-gradient(ellipse at 50% 30%, #0a2030 0%, #030810 100%);
  display: none;
  flex-direction: column;
  align-items: center;
  padding: 16px;
  z-index: 300;
}

.quidditch-title {
  font-family: var(--font-title);
  font-size: 24px;
  color: var(--gold);
  margin-bottom: 16px;
  text-shadow: var(--glow-gold);
}

.quidditch-field {
  width: 100%;
  max-width: 500px;
  height: 200px;
  background: radial-gradient(ellipse at center, #1a4a1a 0%, #0a2a0a 100%);
  border: 2px solid rgba(240,192,64,0.3);
  border-radius: 50%;
  position: relative;
  margin: 8px 0;
  overflow: hidden;
}

.quidditch-player {
  position: absolute;
  font-size: 24px;
  cursor: pointer;
  transition: all 0.2s;
}

.quidditch-snitch {
  position: absolute;
  font-size: 14px;
  animation: snitchFly 2s ease-in-out infinite;
}

@keyframes snitchFly {
  0% { transform: translate(0,0) rotate(0deg); }
  25% { transform: translate(30px,-20px) rotate(90deg); }
  50% { transform: translate(-20px,30px) rotate(180deg); }
  75% { transform: translate(40px,10px) rotate(270deg); }
  100% { transform: translate(0,0) rotate(360deg); }
}

.quidditch-score {
  font-family: var(--font-ui);
  font-size: 20px;
  color: var(--gold);
  margin: 8px 0;
  letter-spacing: 4px;
}

.quidditch-timer {
  font-family: var(--font-ui);
  font-size: 14px;
  color: var(--parchment-dark);
}

.quidditch-controls {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
  max-width: 300px;
  width: 100%;
  margin-top: 12px;
}

.q-btn {
  background: rgba(240,192,64,0.1);
  border: 1px solid var(--gold-dim);
  border-radius: 6px;
  padding: 12px;
  color: var(--gold);
  font-family: var(--font-ui);
  font-size: 12px;
  cursor: pointer;
  letter-spacing: 1px;
  transition: all 0.3s;
  display: flex;
  align-items: center;
